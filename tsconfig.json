{
  "compilerOptions": {
    "target":                          "ES2022",
    "module":                          "commonjs",
    "lib":                             ["ES2022"],
    "outDir":                          "./dist",
    "rootDir":                         "./src",
    "strict":                          true,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":               true,
    "baseUrl":                         ".",
    "paths": {
      "@pages/*":    ["src/pages/*"],
      "@utils/*":    ["src/utils/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@types/*":    ["src/types/*"],
      "@config/*":   ["config/*"]
    }
  },
  "include": ["src/**/*.ts", "config/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
