# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets to source control.
# ─────────────────────────────────────────────────────────────────

# Active environment: development | staging | production
ENV=development

# Base URLs — one per environment
DEV_BASE_URL=https://dev.example.com
STAGING_BASE_URL=https://staging.example.com
PROD_BASE_URL=https://example.com

# Test credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=

# API (optional)
API_BASE_URL=https://api.example.com
API_KEY=

# Browser overrides (optional — defaults set in playwright.config.ts)
HEADLESS=true
SLOW_MO=0
DEFAULT_TIMEOUT=30000

# Static auth token for token-injection strategy (optional)
# AUTH_TOKEN=
